# =================================================================
# TAGLINE — Environment Variables
# =================================================================
# Copy these into Vercel: Settings > Environment Variables
# DO NOT commit a real .env file with secrets to GitHub
# =================================================================

# ----- SUPABASE (database + auth) -----
# Get from: https://supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Public keys (sent to browser, prefixed with NEXT_PUBLIC or shown in HTML)
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ----- STRIPE (payments) -----
# Get from: https://dashboard.stripe.com → Developers → API keys
# Use TEST keys (sk_test_..., pk_test_...) until you're ready for real money
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PUBLIC_STRIPE_KEY=pk_test_...

# ----- RESEND (transactional email) -----
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
FROM_EMAIL=orders@yourdomain.com
ADMIN_EMAIL=you@yourdomain.com

# ----- NOWPAYMENTS (crypto) -----
# Optional — site works without these (the "Pay with crypto" button stays hidden).
# Get from: https://nowpayments.io → Account → Store Settings
# Always enable "Auto-conversion to USD" in your NowPayments dashboard.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ----- ADMIN ACCESS -----
# Generate with: openssl rand -hex 32
# Or any random 32+ char string
ADMIN_API_KEY=replace-with-random-32-character-string

# ----- SITE -----
# Your live URL (no trailing slash)
SITE_URL=https://your-site.vercel.app
