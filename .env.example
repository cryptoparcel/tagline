# =================================================================
# TAGLINE — Environment Variables
# =================================================================
# Copy these into Vercel: Settings > Environment Variables
# DO NOT commit a real .env file with secrets to GitHub
# =================================================================

# ----- SUPABASE (database + auth) -----
# Get from: https://supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Public keys (sent to browser, prefixed with NEXT_PUBLIC or shown in HTML)
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ----- STRIPE (payments) -----
# Get from: https://dashboard.stripe.com → Developers → API keys
# Use TEST keys (sk_test_..., pk_test_...) until you're ready for real money
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PUBLIC_STRIPE_KEY=pk_test_...

# ----- RESEND (transactional email) -----
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
FROM_EMAIL=orders@yourdomain.com
ADMIN_EMAIL=you@yourdomain.com

# ----- NOWPAYMENTS (crypto) -----
# Optional — site works without these (the "Pay with crypto" button stays hidden).
# Get from: https://nowpayments.io → Account → Store Settings
# Always enable "Auto-conversion to USD" in your NowPayments dashboard.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ----- DISCOUNT BANNERS (GovX or any verification provider) -----
# Optional — each is a separate verification group. Set the URL only for
# groups you want to enable; the cart shows one small banner per group.
# Each URL points to the verification page hosted by your provider; the
# provider returns a one-time discount code that the customer pastes
# into Stripe Checkout's promo-code field. Make sure each code matches
# a Stripe Coupon you've created.
# (GOVX_VERIFY_URL is the legacy alias for GOVX_VETERAN_URL — keep
# whichever you already use.)
GOVX_VETERAN_URL=
VETERAN_DISCOUNT_PERCENT=10
GOVX_FIRSTRESP_URL=
FIRSTRESP_DISCOUNT_PERCENT=10
GOVX_STUDENT_URL=
STUDENT_DISCOUNT_PERCENT=10
GOVX_TEACHER_URL=
TEACHER_DISCOUNT_PERCENT=10

# ----- SOFT-LAUNCH ACCESS GATE -----
# Optional. When ACCESS_GATE_ENABLED=true, all page requests redirect to
# /launch unless they have a valid passcode cookie. Whitelisted: known
# crawlers (Googlebot etc.), /api/*, /privacy, /terms, /sitemap.xml, /robots.txt.
# ACCESS_CODES is a comma-separated list of valid codes (e.g. "VIP-001,VIP-002").
# Hand them out individually so you can revoke per-person if needed.
ACCESS_GATE_ENABLED=false
ACCESS_CODES=

# ----- VERCEL CRON (pending-order cleanup) -----
# Required for the daily /api/cleanup-pending cron to authenticate.
# Generate with: openssl rand -hex 32
# Set this in Vercel env vars; Vercel auto-sends it as Bearer auth on cron hits.
CRON_SECRET=

# ----- ADMIN ACCESS -----
# Generate with: openssl rand -hex 32
# Or any random 32+ char string
ADMIN_API_KEY=replace-with-random-32-character-string

# ----- SITE -----
# Your live URL (no trailing slash)
SITE_URL=https://your-site.vercel.app
